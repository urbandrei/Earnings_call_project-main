# Human-handoff working area (e.g. rater packages with rendered transcripts = licensed
# payload). HANDOFF.md (the root queue file) IS tracked; this lowercase dir is not.
/handoff/

# Data payloads — tracked via committed manifests (data/manifests/), never in git.
# Anchored to the repo root (src/ecvol/data is code); data/* + negation because
# git cannot re-include below an excluded directory.
/data/*
!/data/manifests/
!/data/identity/
!/data/coverage/
!/data/splits/
!/data/results/

# Run outputs
/artifacts/

# Legacy bulk binaries (see DECISIONS.md 2026-06-12): third-party literature PDFs
# and slides are not redistributable; notebooks/README/Paper.pdf ARE tracked.
legacy/papers/
legacy/PowerPoint.pptx

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
dist/

# LaTeX paper build artifacts (paper/main.pdf IS tracked; aux files are not).
/paper/*.aux
/paper/*.bbl
/paper/*.blg
/paper/*.log
/paper/*.out
/paper/*.toc
/paper/*.lof
/paper/*.lot
/paper/*.fls
/paper/*.fdb_latexmk
/paper/*.synctex.gz
/paper/sections/*.aux
/paper/_preview_*.png

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Secrets
.env

# Claude Code session state (ephemeral lock for scheduled wakeups)
/.claude/scheduled_tasks.lock
# Machine-specific Claude Code overrides (settings.json + hooks ARE committed)
/.claude/settings.local.json

# OS noise
Thumbs.db
.DS_Store
UNDERMIND_BRIEF.md
.gitignore
.gitignore
UNDERMIND_QUERY.md
setup.md
